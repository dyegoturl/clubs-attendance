NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Email (SMTP — use Resend, SendGrid, or any SMTP provider)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@uaejjf-attendance.com

# WhatsApp (Meta Business API — optional)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Cron job secret (set a random strong string; pass in Vercel cron Authorization header)
CRON_SECRET=your_random_secret_here
